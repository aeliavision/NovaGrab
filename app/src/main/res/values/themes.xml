<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NovaGrab" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.SmartVideoLoader" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.SmartVideoLoader.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/obsidian_background</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartVideoLoader</item>
    </style>
</resources>